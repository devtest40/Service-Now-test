        <value>(function execute(inputs, outputs) {&#13;
&#13;
    try {&#13;
        var r = new sn_ws.RESTMessageV2('Rebrickable_API', 'Get Set Details');&#13;
&#13;
        // pass input&#13;
        r.setStringParameterNoEscape('set_number', inputs.set_number);&#13;
&#13;
        var response = r.execute();&#13;
        var responseBody = response.getBody();&#13;
        var status = response.getStatusCode();&#13;
&#13;
        // parse JSON&#13;
        var data = JSON.parse(responseBody);&#13;
&#13;
        // outputs&#13;
        outputs.name = data.name;&#13;
        outputs.year = data.year;&#13;
        outputs.num_parts = data.num_parts;&#13;
        outputs.status = status;&#13;
&#13;
    } catch (ex) {&#13;
        outputs.error = ex.message;&#13;
    }&#13;
&#13;
})(inputs, outputs);</value>
