        <value>(function execute(inputs, outputs) {&#13;
&#13;
    try {&#13;
        var r = new sn_ws.RESTMessageV2('Rebrickable_API', 'Get Set Details');&#13;
&#13;
        r.setQueryParameter('min_parts', inputs.min_parts);&#13;
        r.setQueryParameter('max_parts', inputs.max_parts);&#13;
&#13;
        var response = r.execute();&#13;
        var body = response.getBody();&#13;
        var status = response.getStatusCode();&#13;
&#13;
        outputs.result = body;           // string&#13;
        outputs.status = status;         // integer&#13;
&#13;
        &#13;
        outputs.__action_status__ = {&#13;
            code: 0,&#13;
            message: "Success"&#13;
        };&#13;
&#13;
    } catch (ex) {&#13;
&#13;
        outputs.status = 500;&#13;
        outputs.error = ex.message.toString();&#13;
&#13;
        // FIX (important)&#13;
        outputs.__action_status__ = {&#13;
            code: 1,&#13;
            message: ex.message.toString()&#13;
        };&#13;
    }&#13;
&#13;
})(inputs, outputs);</value>
